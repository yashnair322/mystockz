# ---------------------------------------------------------------------------
# Mystockz — environment variable template
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Production example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Local dev ONLY — allows a non-SSL local Postgres. REMOVE in production so SSL is enforced.
# DATABASE_SSL_DISABLED=true

# Flask session signing key. MUST be a persistent random string of at least 32 chars.
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Email (SMTP) settings — used for verification / password-reset mails.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
# For Gmail use a 16-char App Password, not your account password.
MAIL_PASSWORD=your_email_app_password
MAIL_DEFAULT_SENDER=your_email@example.com

# Where admin notifications are sent.
ADMIN_EMAIL=admin@example.com

# Razorpay API keys (get from the Razorpay dashboard).
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth client id (if using Google sign-in).
GOOGLE_CLIENT_ID=your_google_client_id

# Set to True only for local development. Keep False/unset in production.
FLASK_DEBUG=False

# Port the app listens on (defaults to 5000 if unset).
# PORT=5000

# Optional: Redis for server-side sessions + rate limiting (recommended in production).
# REDIS_URL=redis://localhost:6379/0
